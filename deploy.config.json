{
  "defaults": {
    "branch": "main"
  },
  "targets": {
    "igygrow": {
      "format": "html",
      "repo": "GrynowDev/igygrow.com",
      "branch": "main",
      "pathPrefix": "blog/",
      "siteName": "Igygrow",
      "url": "https://www.igygrow.com/blog/",
      "tokenEnv": "IGYGROW_GITHUB_TOKEN",
      "referencePath": "blog/my-wall-best-tech-platform-for-creators-and-brands.html",
      "index": {
        "path": "blog.html",
        "cardAnchor": "<div class=\"col-lg-4 col-md-6 col-sm-4\">",
        "linkPrefix": "./",
        "thumbnail": "./assets/blog-banner.webp"
      }
    }
  }
}
